{
  "name": "piki",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "install:web": "pnpm --filter piki-web install",
    "dev:web": "pnpm --filter piki-web dev",
    "build:web": "pnpm --filter piki-web build",
    "install:app": "pnpm --filter piki-app install",
    "dev:app": "pnpm --filter piki-app start"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-turbo": "^2.8.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.21",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.50.0"
  },
  "packageManager": "pnpm@10.17.0",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.1.17",
      "@types/react-dom": "~19.1.0"
    },
    "patchedDependencies": {
      "xcode@3.0.1": "apps/app/patches/xcode+3.0.1.patch"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
