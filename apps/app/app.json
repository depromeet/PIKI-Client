{
  "expo": {
    "name": "PIKI",
    "slug": "piki",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "piki",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "day.no30s.piki",
      "entitlements": {
        "com.apple.security.application-groups": ["group.day.no30s.piki"]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "AppGroup": "group.day.no30s.piki",
        "AppGroupIdentifier": "group.day.no30s.piki"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          }
        ]
      }
    },
    "android": {
      "package": "day.no30s.piki",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "상품 이미지를 선택하기 위해 사진 보관함 접근 권한이 필요합니다."
        }
      ],
      [
        "expo-share-intent",
        {
          "disableIOS": true,
          "androidIntentFilters": ["text/*", "image/*"],
          "androidMultiIntentFilters": ["image/*"]
        }
      ],
      [
        "expo-share-extension",
        {
          "activationRules": [
            {
              "type": "image",
              "max": 1
            },
            {
              "type": "text"
            },
            {
              "type": "url",
              "max": 1
            }
          ],
          "excludedPackages": [
            "expo-dev-client",
            "expo-splash-screen",
            "expo-updates",
            "expo-share-intent"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "576644de-9cba-4457-82a2-562f7dd89d92",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "PIKIShareExtension",
                  "bundleIdentifier": "day.no30s.piki.ShareExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": ["group.day.no30s.piki"]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "owner": "no-30s"
  }
}
